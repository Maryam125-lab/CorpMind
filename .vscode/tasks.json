{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: create venv with Python 3.12",
      "type": "shell",
      "command": "py -3.12 -m venv backend/.venv",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: install dependencies",
      "type": "shell",
      "command": "backend/.venv/Scripts/python.exe -m pip install -r backend/requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: run API",
      "type": "shell",
      "command": "backend/.venv/Scripts/python.exe -m uvicorn app.main:app --reload --port 8010",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: install dependencies",
      "type": "shell",
      "command": "npm.cmd install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: run dev server",
      "type": "shell",
      "command": "npm.cmd run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: build",
      "type": "shell",
      "command": "npm.cmd run build",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    }
  ]
}
